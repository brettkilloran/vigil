## Copy to `.env.local` and fill in your values.
## This file is not used at runtime.

# Neon Postgres connection string (omit → app shows setup until a snapshot exists in this browser)
# Heartgarden reads NEON_DATABASE_URL first, then DATABASE_URL (Neon’s default name in some templates).
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB

# Anthropic (lore Q&A, import extract, per-item lore summary on index) — see docs/FOLLOW_UP.md
# ANTHROPIC_API_KEY=
# ANTHROPIC_LORE_MODEL=claude-sonnet-4-20250514

# OpenAI (text embeddings for vault semantic search + hybrid lore retrieval)
# OPENAI_API_KEY=
# HEARTGARDEN_EMBEDDING_MODEL=text-embedding-3-small

# Disable POST /api/lore/query (e.g. public deploy before auth) — set on Vercel Production/Preview as needed
# HEARTGARDEN_LORE_QUERY_DISABLED=1

# Vault tuning (optional)
# HEARTGARDEN_VAULT_DEBUG=1 — console.debug hybrid retrieval (query preview, RRF top ranks)
# HEARTGARDEN_INDEX_AFTER_PATCH=1 — Next.js `after()` reindex on PATCH/create (server); can overlap client debounced index
# HEARTGARDEN_INDEX_SKIP_LORE_META=1 — embeddings only; skip Anthropic lore summary/aliases on index/reindex when not overridden

# Cloudflare R2 (optional; direct browser upload via POST /api/upload/presign + PUT)
# Create S3 API token + bucket; bind a public r2.dev hostname or custom domain for reads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public GET origin for uploaded keys, e.g. https://pub-xxxx.r2.dev (no trailing slash)
R2_PUBLIC_BASE_URL=

# MCP helper: default space when calling vigil_list_items without args
# HEARTGARDEN_DEFAULT_SPACE_ID=
# HEARTGARDEN_APP_URL=http://localhost:3000
# Same key gates vigil_patch_item and POST /api/spaces/:id/reindex from MCP
# HEARTGARDEN_MCP_WRITE_KEY=

# vault:reindex script (scripts/vault-reindex-all.mjs) — app must be listening here
# HEARTGARDEN_APP_URL=http://127.0.0.1:3000
# VAULT_REINDEX_SPACE_ID=
# VAULT_REINDEX_SKIP_LORE=1
# VAULT_REINDEX_DRY=1
# VAULT_REINDEX_DELAY_MS=120
