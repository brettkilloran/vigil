## Copy to `.env.local` and fill in your values.
## This file is not used at runtime.

# Neon Postgres connection string (omit for local-only demo mode)
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB

# OpenAI (optional: POST /api/items/[id]/embed for embeddings)
OPENAI_API_KEY=

# Cloudflare R2 (optional; presigned upload stub at /api/upload/presign)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# MCP helper: default space when calling vigil_list_items without args
# VIGIL_DEFAULT_SPACE_ID=
# VIGIL_APP_URL=http://localhost:3000
