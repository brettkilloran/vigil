## Copy to `.env.local` and fill in your values.
## This file is not used at runtime.

# Neon Postgres connection string
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# OpenAI (semantic search + future extraction)
OPENAI_API_KEY=

# Single-user mode: UUID used as the "owner" for your spaces/items.
# If unset, we’ll create a row on first run (Phase 1 canvas CRUD).
VIGIL_OWNER_ID=

