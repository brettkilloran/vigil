{
  "name": "heartgarden",
  "version": "0.1.0",
  "private": true,
  "description": "heartgarden — infinite canvas for solo TTRPG worldbuilding",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:app": "next dev --webpack --port 3000",
    "dev:storybook": "storybook dev --port 6006 --host 0.0.0.0 --disable-telemetry --no-open",
    "dev:surfaces": "concurrently -k -n APP,SB -c cyan,magenta \"npm run dev:app\" \"npm run dev:storybook\"",
    "build": "next build",
    "check": "npm run lint && npm run build",
    "check:all": "npm run check && npm run build-storybook",
    "verify:foundation-sync": "node ./scripts/verify-foundation-sync.mjs",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test e2e/visual",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:unit": "vitest run",
    "start": "next start",
    "lint": "eslint",
    "db:ensure-pgvector": "node ./scripts/ensure-pgvector.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "mcp": "node ./scripts/mcp-server.mjs",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0 --disable-telemetry --no-open",
    "build-storybook": "storybook build",
    "preview-storybook": "npx --yes serve storybook-static -l 6007 --no-clipboard",
    "storybook:static": "npm run build-storybook && npm run preview-storybook"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/postcss": "^4.1.11",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@use-gesture/react": "^10.3.1",
    "d3-force": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.4.7",
    "immer": "^10.1.1",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "postcss": "^8.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "snd-lib": "^1.2.4",
    "tailwindcss": "^4.1.11",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/nextjs": "^10.3.4",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-storybook": "^10.3.4",
    "html2canvas": "^1.4.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
