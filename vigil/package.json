{
  "name": "heartgarden",
  "version": "0.9.1",
  "private": true,
  "description": "heartgarden — infinite canvas for solo TTRPG worldbuilding",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:app": "next dev --webpack --port 3000",
    "predev:storybook": "node ./scripts/storybook-start-hint.mjs",
    "dev:storybook": "npx --no-install storybook dev --port 6006 --host 127.0.0.1 --disable-telemetry --no-open --ci",
    "dev:surfaces": "concurrently -k -n APP,SB -c cyan,magenta \"npm run dev:app\" \"npm run dev:storybook\"",
    "build": "next build",
    "check": "npm run lint && npm run build",
    "check:all": "npm run check && npm run build-storybook",
    "reinstall": "node ./scripts/reinstall-deps.mjs",
    "lockfile:regenerate-linux": "node ./scripts/regenerate-package-lock-linux.mjs",
    "verify:package-lock-ci": "node ./scripts/verify-package-lock-ci.mjs",
    "verify:foundation-sync": "node ./scripts/verify-foundation-sync.mjs",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test e2e/visual",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:unit": "vitest run",
    "start": "next start",
    "lint": "eslint",
    "prepare": "node ./scripts/install-git-hooks.mjs",
    "secrets:protect": "gitleaks-secret-scanner -c ../.gitleaks.toml --no-banner",
    "secrets:scan": "gitleaks-secret-scanner --diff-mode history -c ../.gitleaks.toml --no-banner",
    "db:ensure-pgvector": "node ./scripts/ensure-pgvector.mjs",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:vault-sql": "node ./scripts/vault-sql-migrate.mjs",
    "db:vault-setup": "npm run db:ensure-pgvector && npm run db:push:force && npm run db:vault-sql",
    "vault:reindex": "node ./scripts/vault-reindex-all.mjs",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "mcp": "node ./scripts/mcp-server.mjs",
    "prestorybook": "node ./scripts/storybook-start-hint.mjs",
    "storybook": "npx --no-install storybook dev -p 6006 --host 127.0.0.1 --disable-telemetry --no-open --ci",
    "storybook:lan": "npx --no-install storybook dev -p 6006 --host 0.0.0.0 --disable-telemetry --no-open --ci",
    "storybook:doctor": "node ./scripts/storybook-doctor.mjs",
    "build-storybook": "npx --no-install storybook build",
    "preview-storybook": "npx --yes serve storybook-static -l 6007 --no-clipboard",
    "storybook:static": "npm run build-storybook && npm run preview-storybook",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.1.11",
    "d3-force": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "postcss": "^8.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "snd-lib": "^1.2.4",
    "tailwindcss": "^4.1.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/nextjs": "^10.3.4",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-storybook": "^10.3.4",
    "gitleaks-secret-scanner": "^2.1.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "react-refresh": "^0.18.0",
    "storybook": "^10.3.4",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
