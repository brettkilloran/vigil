{
  "name": "heartgarden",
  "version": "0.9.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "heartgarden — infinite canvas for solo TTRPG worldbuilding",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --webpack --port 3000",
    "dev:app": "next dev --webpack --port 3000",
    "predev:storybook": "node ./scripts/storybook-start-hint.mjs",
    "dev:storybook": "pnpm exec storybook dev --port 6006 --host 127.0.0.1 --disable-telemetry --no-open --ci",
    "dev:surfaces": "concurrently -k -n APP,SB -c cyan,magenta \"pnpm run dev:app\" \"pnpm run dev:storybook\"",
    "build": "next build --webpack",
    "check:button-casing": "node ./scripts/check-vigil-button-casing.mjs",
    "check": "pnpm run check:button-casing && pnpm run lint && pnpm run build",
    "analyze": "cross-env ANALYZE=1 pnpm run build",
    "check:all": "pnpm run check && pnpm run build-storybook",
    "reinstall": "node ./scripts/reinstall-deps.mjs",
    "verify:foundation-sync": "node ./scripts/verify-foundation-sync.mjs",
    "verify:editor-cutover": "node ./scripts/verify-editor-cutover.mjs",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test e2e/visual",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:unit": "vitest run",
    "start": "next start",
    "lint": "eslint",
    "prepare": "node ./scripts/install-git-hooks.mjs",
    "secrets:protect": "gitleaks-secret-scanner -c ../.gitleaks.toml --no-banner",
    "secrets:scan": "gitleaks-secret-scanner --diff-mode history -c ../.gitleaks.toml --no-banner",
    "db:ensure-pgvector": "node ./scripts/ensure-pgvector.mjs",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:vault-sql": "node ./scripts/vault-sql-migrate.mjs",
    "db:vault-setup": "pnpm run db:ensure-pgvector && pnpm run db:push:force && pnpm run db:vault-sql",
    "vault:reindex": "node ./scripts/vault-reindex-all.mjs",
    "db:sever-worlds": "pnpm exec tsx ./scripts/sever-player-gm-worlds.ts",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "mcp": "pnpm exec tsx ./scripts/mcp-server.ts",
    "mcp:smoke": "pnpm exec tsx ./scripts/mcp-prod-smoke.ts",
    "realtime": "pnpm exec tsx ./scripts/realtime-server.ts",
    "realtime:redis-smoke": "pnpm exec tsx ./scripts/realtime-redis-smoke.ts",
    "prestorybook": "node ./scripts/storybook-start-hint.mjs",
    "storybook": "pnpm exec storybook dev -p 6006 --host 127.0.0.1 --disable-telemetry --no-open --ci",
    "storybook:lan": "pnpm exec storybook dev -p 6006 --host 0.0.0.0 --disable-telemetry --no-open --ci",
    "storybook:doctor": "node ./scripts/storybook-doctor.mjs",
    "build-storybook": "pnpm exec storybook build",
    "preview-storybook": "pnpm dlx serve storybook-static -l 6007 --no-clipboard",
    "storybook:static": "pnpm run build-storybook && pnpm run preview-storybook",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-dropcursor": "^3.22.3",
    "@tiptap/extension-gapcursor": "^3.22.3",
    "@tiptap/extension-horizontal-rule": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/html": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "d3-force": "^3.0.0",
    "d3-force-3d": "^3.0.6",
    "drizzle-orm": "^0.45.2",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "lowlight": "^3.3.0",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "pg": "^8.20.0",
    "postcss": "^8.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.11.0",
    "snd-lib": "^1.2.4",
    "tailwindcss": "^4.1.11",
    "three": "^0.184.0",
    "troika-three-text": "^0.52.4",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/nextjs": "^10.3.4",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-storybook": "^10.3.4",
    "gitleaks-secret-scanner": "^2.1.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "react-refresh": "^0.18.0",
    "storybook": "^10.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "gitleaks-secret-scanner"
    ]
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "0.1.80"
  }
}
