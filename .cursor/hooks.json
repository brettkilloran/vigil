{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "mise format"
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/hooks/review-heavy-fix-kickoff.mjs",
        "matcher": "generalPurpose",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}
